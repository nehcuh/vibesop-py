#!/bin/bash
# VibeSOP Route Hook — UserPromptSubmit handler
# Generated by VibeSOP v{{ version }}
#
# Platform: Claude Code (requires hook extension support)
# Purpose: Trigger VibeSOP routing and inject skill context
#
# Usage:
#   1. Configure in .claude/settings.json under hooks.UserPromptSubmit
#   2. Or call manually: bash ~/.claude/hooks/vibesop-route.sh
#
# Input: JSON via stdin with field "user_prompt"
# Output: JSON with optional "systemMessage" and "additionalContext"

set -e

INPUT=$(cat)
QUERY=$(echo "$INPUT" | jq -r '.user_prompt // empty')

# Skip empty or short queries (avoid over-routing)
if [ -z "$QUERY" ] || [ "$(printf '%s' "$QUERY" | wc -m | tr -d ' ')" -lt 10 ]; then
    echo '{}'
    exit 0
fi

# Skip meta queries about VibeSOP itself
if echo "$QUERY" | grep -qiE 'vibe\s+(route|skill|config)|why.*routing|how.*skill'; then
    echo '{}'
    exit 0
fi

# Detect explicit skill overrides (bypass routing)
OVERRIDE=$(echo "$QUERY" | grep -oE '(/[a-z-]+|@[a-z-]+|使用\s+[a-z-]+)' | head -1)
if [ -n "$OVERRIDE" ]; then
    SKILL_ID="${OVERRIDE#/}"
    SKILL_ID="${SKILL_ID#@}"
    SKILL_ID=$(echo "$SKILL_ID" | sed 's/使用 *//')
    echo "{\"systemMessage\": \"🎯 Explicit skill override: $SKILL_ID\", \"hookSpecificOutput\": {\"additionalContext\": \"[EXPLICIT SKILL: $SKILL_ID]\nPlease load and follow this skill.\"}}"
    exit 0
fi

# Call VibeSOP routing (with 3-second timeout to avoid blocking)
RESULT=""
if command -v vibe &> /dev/null; then
    RESULT=$(cd "$CLAUDE_PROJECT_DIR" 2>/dev/null || true; timeout 3 vibe route --auto --json "$QUERY" 2>/dev/null || true)
fi

if [ -z "$RESULT" ]; then
    echo '{}'
    exit 0
fi

# Parse routing result
MODE=$(echo "$RESULT" | jq -r '.mode // "single"')
PRIMARY=$(echo "$RESULT" | jq -r '.primary.skill_id // empty')
CONFIDENCE=$(echo "$RESULT" | jq -r '.primary.confidence // "0"')

if [ "$MODE" = "orchestrated" ] || [ "$MODE" = "orchestrate" ]; then
    # Multi-intent: inject execution plan
    PLAN=$(echo "$RESULT" | jq -r '.execution_plan // empty')
    if [ -n "$PLAN" ]; then
        echo "{\"systemMessage\": \"🔀 VibeSOP detected multiple intents. Execution plan injected.\", \"hookSpecificOutput\": {\"additionalContext\": \"[VibeSOP Execution Plan]\n$PLAN\"}}"
    else
        echo "{\"systemMessage\": \"🔀 VibeSOP detected multiple intents.\"}"
    fi
elif [ -n "$PRIMARY" ] && [ "$PRIMARY" != "fallback-llm" ]; then
    # Single skill: inject skill content (truncated to ~3000 chars)
    SKILL_CONTENT=""
    if command -v vibe &> /dev/null; then
        SKILL_CONTENT=$(timeout 2 vibe skills read "$PRIMARY" 2>/dev/null | head -c 3000 || true)
    fi
    if [ -n "$SKILL_CONTENT" ]; then
        echo "{\"systemMessage\": \"🎯 VibeSOP routed: $PRIMARY (${CONFIDENCE} confidence)\", \"hookSpecificOutput\": {\"additionalContext\": \"[ACTIVE SKILL: $PRIMARY]\n$SKILL_CONTENT\"}}"
    else
        echo "{\"systemMessage\": \"🎯 VibeSOP routed: $PRIMARY (${CONFIDENCE} confidence). Please read skills/$PRIMARY/SKILL.md\"}"
    fi
else
    # No match or fallback
    echo "{\"systemMessage\": \"🤖 VibeSOP: No matching skill found. Proceeding in normal mode.\"}"
fi
