#!/bin/bash
# VibeSOP Track Hook — PreToolUse handler
# Generated by VibeSOP v{{ version }}
#
# Platform: Claude Code (requires hook extension support)
# Purpose: Track tool usage for session context and skill verification
#
# Usage:
#   1. Configure in .claude/settings.json under hooks.PreToolUse
#   2. Or call manually: bash ~/.claude/hooks/vibesop-track.sh
#
# Input: JSON via stdin with fields "tool", "args"
# Output: JSON (usually empty — this hook is for side effects)

set -e

INPUT=$(cat)
TOOL=$(echo "$INPUT" | jq -r '.tool // empty')
ARGS=$(echo "$INPUT" | jq -r '.args // empty')

# Skip if no tool info
if [ -z "$TOOL" ]; then
    echo '{}'
    exit 0
fi

# Log tool use for session context (non-blocking)
if command -v vibe &> /dev/null; then
    # Record tool use in background to avoid blocking
    (
        vibe session record-tool \
            --tool "$TOOL" \
            --args "$ARGS" \
            2>/dev/null || true
    ) &
fi

# Check for completion markers (step transition detection)
if [ "$TOOL" = "Write" ] || [ "$TOOL" = "Bash" ]; then
    MARKER=$(echo "$ARGS" | grep -oE '『步骤\s*[0-9]+\s*完成』|Step\s+[0-9]+\s+completed' | tail -1 || true)
    if [ -n "$MARKER" ]; then
        echo "{\"systemMessage\": \"✅ $MARKER\"}"
        exit 0
    fi
fi

# Default: no output
echo '{}'
