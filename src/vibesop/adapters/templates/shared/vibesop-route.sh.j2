#!/bin/bash
# VibeSOP Route Hook for {{ platform_name }}
# Generated by VibeSOP v{{ version }}
#
# Platform: {{ platform_name }}
# Purpose: {{ purpose }}
#
# Input: JSON via stdin with field "user_prompt", or plain text
# Output: JSON with optional "systemMessage" and "hookSpecificOutput"
#
# Usage:
{% if platform == "claude-code" %}
#   Configure in .claude/settings.json under hooks.UserPromptSubmit
#   Or call manually: bash ~/.claude/hooks/vibesop-route.sh
{% elif platform == "opencode" %}
#   echo "/vibe-help" | bash ~/.config/opencode/hooks/vibesop-route.sh
#   Or source vibesop-env.sh for automatic handling.
{% elif platform == "kimi-cli" %}
#   Configure [[hooks]] in config.toml:
#   [[hooks]]
#   name = "vibesop-route"
#   event = "UserPromptSubmit"
#   command = "bash ~/.kimi/hooks/vibesop-route.sh"
{% endif %}

set -e

INPUT=$(cat)

# Try JSON parsing first; fall back to raw input for plain-text use
QUERY=""
if command -v jq &> /dev/null; then
    QUERY=$(echo "$INPUT" | jq -r '.user_prompt // empty' 2>/dev/null || true)
fi
if [ -z "$QUERY" ]; then
    QUERY="$INPUT"
fi

# Skip empty or very short queries (avoid over-routing trivial input)
if [ -z "$QUERY" ] || [ "$(printf '%s' "$QUERY" | wc -m | tr -d ' ')" -lt 10 ]; then
    echo '{}'
    exit 0
fi

# Skip meta queries about VibeSOP itself
if echo "$QUERY" | grep -qiE 'vibe\s+(route|skill|config)|why.*routing|how.*skill'; then
    echo '{}'
    exit 0
fi

# Generate stable conversation ID for multi-turn context
CONVERSATION_ID=""
PROJECT_DIR="${CLAUDE_PROJECT_DIR:-${PWD:-$(pwd)}}"
if command -v sha256sum &> /dev/null; then
    CONVERSATION_ID=$(printf '%s' "$PROJECT_DIR" | sha256sum | cut -c1-16)
elif command -v shasum &> /dev/null; then
    CONVERSATION_ID=$(printf '%s' "$PROJECT_DIR" | shasum -a 256 | cut -c1-16)
elif command -v python3 &> /dev/null; then
    CONVERSATION_ID=$(printf '%s' "$PROJECT_DIR" | python3 -c "import sys, hashlib; print(hashlib.sha256(sys.stdin.read().encode()).hexdigest()[:16])")
fi

CONVERSATION_ARG=""
if [ -n "$CONVERSATION_ID" ]; then
    CONVERSATION_ARG="--conversation $CONVERSATION_ID"
fi

# Detect VibeSOP quick commands (/vibe-*)
if echo "$QUERY" | grep -qE '^/vibe-'; then
    SLASH_RESULT=""
    if command -v vibe &> /dev/null; then
        SLASH_RESULT=$(timeout 3 vibe route $CONVERSATION_ARG --json "$QUERY" 2>/dev/null || true)
    fi
    if [ -n "$SLASH_RESULT" ]; then
        SLASH_MSG=$(echo "$SLASH_RESULT" | jq -r '.message // empty')
        if [ -n "$SLASH_MSG" ]; then
            echo "{\"systemMessage\": \"📎 VibeSOP: $SLASH_MSG\"}"
            exit 0
        fi
    fi
    echo "{\"systemMessage\": \"📎 VibeSOP quick command: $QUERY\"}"
    exit 0
fi

{% if enable_explicit_overrides %}
# Detect explicit skill overrides (bypass routing)
OVERRIDE=$(echo "$QUERY" | grep -oE '(/[a-z-]+|@[a-z-]+|使用\s+[a-z-]+)' | head -1)
if [ -n "$OVERRIDE" ]; then
    SKILL_ID="${OVERRIDE#/}"
    SKILL_ID="${SKILL_ID#@}"
    SKILL_ID=$(echo "$SKILL_ID" | sed 's/使用 *//')
    echo "{\"systemMessage\": \"🎯 Explicit skill override: $SKILL_ID\", \"hookSpecificOutput\": {\"additionalContext\": \"[EXPLICIT SKILL: $SKILL_ID]\nPlease load and follow this skill.\"}}"
    exit 0
fi
{% endif %}

# Call VibeSOP routing (with timeout to avoid blocking)
RESULT=""
if command -v vibe &> /dev/null; then
    RESULT=$(timeout 3 vibe route --auto $CONVERSATION_ARG --json "$QUERY" 2>/dev/null || true)
fi

if [ -z "$RESULT" ]; then
    echo '{}'
    exit 0
fi

{% if enable_orchestration %}
# Parse routing result (orchestration-aware)
MODE=$(echo "$RESULT" | jq -r '.mode // "single"')
PRIMARY=$(echo "$RESULT" | jq -r '.primary.skill_id // empty')
CONFIDENCE=$(echo "$RESULT" | jq -r '.primary.confidence // "0"')

if [ "$MODE" = "orchestrated" ] || [ "$MODE" = "orchestrate" ]; then
    PLAN=$(echo "$RESULT" | jq -r '.execution_plan // empty')
    if [ -n "$PLAN" ]; then
        echo "{\"systemMessage\": \"🔀 VibeSOP detected multiple intents. Execution plan injected.\", \"hookSpecificOutput\": {\"additionalContext\": \"[VibeSOP Execution Plan]\n$PLAN\"}}"
    else
        echo "{\"systemMessage\": \"🔀 VibeSOP detected multiple intents.\"}"
    fi
{% else %}
PRIMARY=$(echo "$RESULT" | jq -r '.primary.skill_id // empty')
CONFIDENCE=$(echo "$RESULT" | jq -r '.primary.confidence // "0"')
{% endif %}

if [ -n "$PRIMARY" ] && [ "$PRIMARY" != "fallback-llm" ]; then
    SKILL_CONTENT=""
    if command -v vibe &> /dev/null; then
        SKILL_CONTENT=$(timeout 2 vibe skills read "$PRIMARY" 2>/dev/null | head -c 3000 || true)
    fi
{% if include_additional_context %}
    if [ -n "$SKILL_CONTENT" ]; then
        echo "{\"systemMessage\": \"🎯 VibeSOP routed: $PRIMARY (${CONFIDENCE} confidence)\", \"hookSpecificOutput\": {\"additionalContext\": \"[ACTIVE SKILL: $PRIMARY]\n$SKILL_CONTENT\"}}"
    else
        echo "{\"systemMessage\": \"🎯 VibeSOP routed: $PRIMARY (${CONFIDENCE} confidence). Please read skills/$PRIMARY/SKILL.md\"}"
    fi
{% else %}
    if [ -n "$SKILL_CONTENT" ]; then
        echo "{\"systemMessage\": \"🎯 VibeSOP routed: $PRIMARY (${CONFIDENCE} confidence)\"}"
    else
        echo "{\"systemMessage\": \"🎯 VibeSOP routed: $PRIMARY (${CONFIDENCE} confidence).\"}"
    fi
{% endif %}
{% if no_match_message %}
elif [ "$PRIMARY" = "fallback-llm" ]; then
    echo "{\"systemMessage\": \"🤖 VibeSOP: No matching skill found. Proceeding in normal mode.\"}"
{% else %}
else
    echo '{}'
{% endif %}
fi
