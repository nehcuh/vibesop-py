#!/bin/bash
# Pre-tool-use hook for {{ platform }}
# This hook runs before a tool is used
#
# Generated by VibeSOP - DO NOT EDIT MANUALLY

# Configuration
VIBESOP_CONTEXT_TRACKING="${VIBESOP_CONTEXT_TRACKING:-false}"
VIBESOP_REROUTE_CHECK_INTERVAL="${VIBESOP_REROUTE_CHECK_INTERVAL:-5}"

# Tool name is passed as $1
TOOL_NAME="${1:-unknown}"

# Skip if tracking is disabled
if [[ "$VIBESOP_CONTEXT_TRACKING" != "true" ]]; then
    exit 0
fi

# Get current skill if available
CURRENT_SKILL="${VIBESOP_CURRENT_SKILL:-}"
TOOL_COUNT_FILE="${HOME}/.vibesop/tool-count"

# Increment tool use counter
if [[ -f "$TOOL_COUNT_FILE" ]]; then
    TOOL_COUNT=$(cat "$TOOL_COUNT_FILE")
else
    TOOL_COUNT=0
fi

TOOL_COUNT=$((TOOL_COUNT + 1))
echo "$TOOL_COUNT" > "$TOOL_COUNT_FILE"

# Record tool use
if command -v vibe &> /dev/null; then
    # Record tool use asynchronously to avoid blocking
    vibe session record-tool \
        --tool "$TOOL_NAME" \
        --skill "$CURRENT_SKILL" \
        2>/dev/null &

    # Check for re-routing every N tool uses
    if (( TOOL_COUNT % VIBESOP_REROUTE_CHECK_INTERVAL == 0 )); then
        # Get last user message from environment (if available)
        LAST_MESSAGE="${VIBESOP_LAST_MESSAGE:-}"

        if [[ -n "$LAST_MESSAGE" ]] && [[ -n "$CURRENT_SKILL" ]]; then
            # Check if re-routing is suggested
            SUGGESTION=$(vibe session check-reroute \
                "$LAST_MESSAGE" \
                --skill "$CURRENT_SKILL" \
                --json 2>/dev/null || echo "{}")

            # Parse suggestion and notify if needed
            if echo "$SUGGESTION" | grep -q '"should_reroute": true'; then
                echo "[VibeSOP] 💡 Consider switching skills"
                echo "$SUGGESTION" | grep -o '"recommended_skill":"[^"]*"' | cut -d'"' -f4 | xargs -I {} echo "[VibeSOP] Suggested: {}"
            fi
        fi
    fi
fi

# Custom hook logic can be added here
{% if platform == "claude-code" %}
# Claude Code specific logic
case "$TOOL_NAME" in
    "Read"|"Bash"|"Edit")
        # Track high-traffic tools
        ;;
    "AskUserQuestion")
        # User interaction - may indicate phase change
        ;;
esac
{% endif %}

exit 0
