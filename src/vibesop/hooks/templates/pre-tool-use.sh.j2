#!/bin/bash
# Pre-tool-use hook for {{ platform }}
# This hook runs before a tool is used
#
# Generated by VibeSOP - DO NOT EDIT MANUALLY

# Tool name is passed as $1
TOOL_NAME="${1:-unknown}"

echo "[{{ hook_point }}] Tool use detected: $TOOL_NAME"

# Log tool usage
if command -v vibe &> /dev/null; then
    # Note: 'vibe analytics' will be available in v1.2.0
    # This hook is prepared for future analytics feature
    echo "[{{ hook_point }}] Tool $TOOL_NAME used at $(date)"
fi

# Custom hook logic can be added here
{% if platform == "claude-code" %}
# Claude Code specific logic
case "$TOOL_NAME in
    "Read"|"Bash"|"Edit")
        echo "[{{ hook_point }}] High-traffic tool: $TOOL_NAME"
        ;;
esac
{% endif %}

exit 0
