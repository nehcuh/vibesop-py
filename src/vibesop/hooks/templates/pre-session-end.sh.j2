#!/bin/bash
# Pre-session-end hook for {{ platform }}
# This hook runs before the session ends
#
# Generated by VibeSOP - DO NOT EDIT MANUALLY

set -e

# Find and analyze current session
analyze_session() {
    local session_file=""

    # Try to find session file in Claude Code format
    if [ -n "$CLAUDE_SESSION_FILE" ]; then
        session_file="$CLAUDE_SESSION_FILE"
    elif [ -f ".claude/projects/-"*/"*.jsonl" ]; then
        # Find most recent session
        session_file=$(find .claude/projects/-* -name "*.jsonl" -type f -printf '%T@ %p\n' 2>/dev/null | sort -n | tail -1 | cut -d' ' -f2-)
    elif [ -f "session.jsonl" ]; then
        session_file="session.jsonl"
    fi

    # Analyze if found
    if [ -n "$session_file" ] && [ -f "$session_file" ]; then
        echo "[{{ hook_point }}] Analyzing session patterns..."
        vibe auto-analyze-session "$session_file" --quiet || true
    fi
}

# Run analysis
if command -v vibe &> /dev/null; then
    echo "[{{ hook_point }}] Session ending at $(date)"

    # Run automatic analysis
    analyze_session

    echo "[{{ hook_point }}] Session analysis complete"
else
    echo "[{{ hook_point }}] VibeSOP CLI not found, skipping analysis"
fi

# Platform-specific logic
{% if platform == "claude-code" %}
# Additional Claude Code specific logic can go here
{% elif platform == "opencode" %}
# Additional OpenCode specific logic can go here
{% endif %}

exit 0
