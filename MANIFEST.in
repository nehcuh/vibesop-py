include README.md
include README.zh.md
include LICENSE
include CHANGELOG.md
include CONTRIBUTING.md
include pyproject.toml

recursive-include src/vibesop *.py
recursive-include src/vibesop/adapters/templates *.j2 *.md
recursive-include src/vibesop/hooks/templates *.j2
recursive-include src/vibesop/core *.yaml *.yml
recursive-include docs *.md
recursive-include scripts *

exclude .vibe/
exclude .venv/
exclude __pycache__/
exclude *.pyc
exclude .pytest_cache/
exclude .coverage
exclude htmlcov/
exclude .ruff_cache/
exclude .pytest_cache/
exclude *.egg-info/
exclude dist/
exclude build/
